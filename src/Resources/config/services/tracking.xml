<?xml version="1.0" encoding="UTF-8" ?>
<container xmlns="http://symfony.com/schema/dic/services" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- Tracking Proxy Service -->
        <service id="Gally\SyliusPlugin\Service\TrackingProxyService">
            <argument type="service" id="Gally\SyliusPlugin\Repository\GallyConfigurationRepository" />
            <argument type="service" id="logger" />
            <argument type="service" id="http_client" />
        </service>

        <!-- Tracking Controller -->
        <service id="Gally\SyliusPlugin\Controller\Shop\TrackingController" public="true">
            <argument type="service" id="Gally\SyliusPlugin\Service\TrackingProxyService" />
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <tag name="controller.service_arguments" />
        </service>
    </services>
</container>
